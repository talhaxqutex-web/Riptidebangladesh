{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product description" },
        "price": { "type": "number", "description": "Price in BDT" },
        "imageUrl": { "type": "string", "description": "URL to product image" },
        "category": { "type": "string", "description": "Product category" },
        "stockCount": { "type": "number", "description": "Number of items in stock" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "description", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user's review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the product being reviewed" },
        "userId": { "type": "string", "description": "ID of the user who wrote the review" },
        "userEmail": { "type": "string", "description": "Email of the user" },
        "rating": { "type": "number", "description": "Rating from 1 to 5" },
        "comment": { "type": "string", "description": "Review text" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userEmail", "rating", "comment", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's order",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "description": "List of items ordered" },
        "totalAmount": { "type": "number", "description": "Total order amount" },
        "status": { "type": "string", "description": "Order status", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "string", "description": "Shipping address" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon code",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Uppercase coupon code name" },
        "discountAmount": { "type": "number", "description": "Discount value in BDT" },
        "isActive": { "type": "boolean", "description": "Whether the coupon can be applied" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountAmount", "isActive", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "General store settings e.g. shipping fees",
      "type": "object",
      "properties": {
        "insideDhakaCharge": { "type": "number" },
        "outsideDhakaCharge": { "type": "number" }
      },
      "required": ["insideDhakaCharge", "outsideDhakaCharge"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products available in the store"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders placed by users"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons managed by admins"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Storewide settings such as shipping fees"
    }
  }
}
